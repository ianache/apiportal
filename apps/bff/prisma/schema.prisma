generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String            @id @default(uuid())
  sub                   String            @unique
  email                 String            @unique
  name                  String?
  role                  Role              @default(API_DEVELOPER)
  ownedApis             API[]             @relation("ApiOwner")
  approvedVersions      APIVersion[]      @relation("VersionApprover")
  createdVersions       APIVersion[]      @relation("VersionCreator")
  auditLogs             AuditLog[]
  favorites             UserAPIFavorite[]
  createdOrganizations  Organization[]    @relation("OrganizationCreator")
  ownedOrganizations    Organization[]    @relation("OrganizationOwner")
  createdProducts       Product[]         @relation("ProductCreator")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  userId    String
  timestamp DateTime @default(now())
  details   Json?
  user      User     @relation(fields: [userId], references: [id])
}

model API {
  id             String            @id @default(uuid())
  name           String            @unique
  description    String?
  ownerId        String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  domainId       String?
  label          String?
  owner          User              @relation("ApiOwner", fields: [ownerId], references: [id])
  versions       APIVersion[]
  favorites      UserAPIFavorite[]
  organizationId String?
  organization   Organization?     @relation("OrganizationApis", fields: [organizationId], references: [id])

  @@index([domainId])
  @@index([label])
}

model APIVersion {
  id          String        @id @default(uuid())
  apiId       String
  version     String        @default("0.1.0")
  status      APIStatus     @default(DESIGN)
  definition  Json?
  flowConfig  Json?
  createdBy   String
  approvedBy  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  openApiSpec Json?
  endpoints   APIEndpoint[]
  api         API           @relation(fields: [apiId], references: [id], onDelete: Cascade)
  approver    User?         @relation("VersionApprover", fields: [approvedBy], references: [id])
  creator     User          @relation("VersionCreator", fields: [createdBy], references: [id])

  @@unique([apiId, version])
}

model Environment {
  id        String        @id @default(uuid())
  slug      String        @unique
  name      String
  tags      String[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  endpoints APIEndpoint[]
}

model Domain {
  id           String        @id @default(uuid())
  name         String        @unique
  title        String
  description  String?
  labels       String[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  conceptModel Json?
  erModel      Json?
  integrations Integration[]
}

model Integration {
  id          String               @id @default(uuid())
  name        String
  type        String
  description String?
  status      IntegrationStatus    @default(DRAFT)
  icon        String?
  linkedApis  Int                  @default(0)
  domainId    String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  domain      Domain?              @relation(fields: [domainId], references: [id])
  versions    IntegrationVersion[]
}

model IntegrationVersion {
  id            String                   @id @default(uuid())
  version       String
  status        IntegrationVersionStatus @default(Design)
  description   String?
  integrationId String
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  integration   Integration              @relation(fields: [integrationId], references: [id], onDelete: Cascade)
}

model NodeTypeCatalog {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  properties  Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model APIEndpoint {
  id            String      @id @default(uuid())
  versionId     String
  environmentId String
  baseUrl       String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  environment   Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  version       APIVersion  @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, environmentId])
}

model LLMProvider {
  id        String          @id
  label     String
  models    String[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  apiKeys   UserLLMApiKey[]
}

model UserPreferences {
  userId            String   @id
  preferredProvider String   @default("openai")
  preferredModel    String   @default("gpt-4o")
  customApiUrl      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model UserLLMApiKey {
  id         String      @id @default(uuid())
  userId     String
  providerId String
  apiKey     String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  provider   LLMProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId])
}

model UserAPIFavorite {
  id        String   @id @default(uuid())
  userId    String
  apiId     String
  createdAt DateTime @default(now())
  api       API      @relation(fields: [apiId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, apiId])
  @@index([userId])
}

model ApiReviewReport {
  id        String   @id @default(uuid())
  apiId     String
  version   String
  userId    String
  userEmail String
  content   String
  createdAt DateTime @default(now())

  @@index([apiId])
  @@index([userId])
}

model KnowledgePieceType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  fields      Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model KnowledgePiece {
  id        String   @id @default(uuid())
  typeId    String
  domainId  String
  title     String
  content   String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([domainId])
  @@index([typeId])
}

model Organization {
  id          String                      @id @default(uuid())
  name        String                      @unique
  description String?
  createdById String
  createdBy   User                        @relation("OrganizationCreator", fields: [createdById], references: [id])
  ownerId     String?
  owner       User?                       @relation("OrganizationOwner", fields: [ownerId], references: [id])
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  products    Product[]
  apis        API[]                       @relation("OrganizationApis")
  swcis       SoftwareConfigurationItem[]
}

model Product {
  id             String       @id @default(uuid())
  name           String
  description    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User         @relation("ProductCreator", fields: [createdById], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  diagram        Json?
}

model SoftwareConfigurationItem {
  id             String                    @id @default(uuid())
  name           String
  description    String?
  type           SoftwareConfigurationType @default(MICROSERVICE)
  organizationId String
  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
}

enum SoftwareConfigurationType {
  API
  DATABASE
  MICROSERVICE
  FRONTEND
  EXTERNAL_SERVICE
  MESSAGE_BROKER
}

enum SoftwareConfigurationDependencyType {
  REST_CALL
  GRPC
  PUBSUB
  JDBC
  SOAP
}

enum Role {
  API_MANAGER
  API_DESIGNER
  API_DEVELOPER
}

enum APIStatus {
  DESIGN
  REVIEW
  APPROVED
  PUBLISHED
  DEPRECATED
  RETIRED
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  DRAFT
  ERROR
}

enum IntegrationVersionStatus {
  Design
  Testing
  Published
  Deprecated
}
